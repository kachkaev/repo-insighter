{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboardApproval",
    ":disableDigestUpdates",
    ":maintainLockFilesWeekly",
    ":semanticCommitsDisabled",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "packageRules": [
    {
      "description": "Group packages released in lockstep from the Effect monorepo. Renovate's own `group:monorepos` preset matches on `matchSourceUrls`, which does not work here: `monorepo.json` lists `Effect-TS/effect-smol`, while the published packages point at `Effect-TS/effect`. Matching on package names instead keeps the group working no matter where the sources move.",
      "groupName": "effect monorepo",
      "matchManagers": ["npm"],
      "matchPackageNames": ["effect", "@effect/**"]
    },
    {
      "description": "Group packages released in lockstep from the React monorepo. Same story as above: `monorepo.json` lists `facebook/react`, while the published packages point at `react/react`.",
      "groupName": "react monorepo",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "react",
        "react-dom",
        "react-is",
        "@types/react",
        "@types/react-dom",
        "@types/react-is"
      ]
    },
    {
      "autoApprove": true,
      "automerge": true,
      "dependencyDashboardApproval": false,
      "enabled": true,
      "minimumReleaseAge": "2 days",
      "matchManagers": ["npm"],
      "matchPackageNames": ["/^pnpm$/"],
      "schedule": ["every weekend"]
    },
    {
      "autoApprove": true,
      "automerge": true,
      "dependencyDashboardApproval": false,
      "enabled": true,
      "matchUpdateTypes": ["patch"],
      "matchCurrentValue": "!/^0\\./",
      "matchManagers": ["npm"],
      "minimumReleaseAge": "2 days",
      "schedule": ["every weekend"]
    },
    {
      "autoApprove": true,
      "automerge": true,
      "dependencyDashboardApproval": false,
      "enabled": true,
      "matchDepTypes": ["devDependencies"],
      "matchManagers": ["npm"],
      "minimumReleaseAge": "2 days",
      "schedule": ["every weekend"]
    }
  ],
  "postUpdateOptions": ["pnpmDedupe"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 1,
  "rangeStrategy": "pin",
  "timezone": "Etc/UTC"
}
